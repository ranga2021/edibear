# Copy into Dokploy → your PHP application → Environment (or create a .env your runtime loads).
# Use the INTERNAL database host from Dokploy’s MySQL service — never use localhost from the app container unless MySQL runs in the same container.

DB_HOST=REPLACE_WITH_DOKPLOY_INTERNAL_DB_HOSTNAME
DB_PORT=3306
DB_NAME=edibear
DB_USERNAME=edibear-user
DB_PASSWORD=REPLACE_WITH_YOUR_PASSWORD

# Optional: MariaDB image sometimes exposes these instead of DB_* — dbconfig.php reads both.
# MYSQL_HOST=
# MYSQL_DATABASE=
# MYSQL_USER=
# MYSQL_PASSWORD=

# Optional: if set, admin-area/signup-admin.php (first admin only) requires this token in the form.
# ADMIN_BOOTSTRAP_TOKEN=

# Docker / Dokploy: persist uploaded product images (and similar upload dirs) or they disappear on rebuild.
# Mount a host path or named volume onto the container path, e.g. /var/www/html/img/products
# (WORKDIR in Dockerfile is /var/www/html). Ensure the directory is writable by www-data.
